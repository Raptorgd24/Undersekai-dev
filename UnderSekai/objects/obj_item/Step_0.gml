function execute_action() {
    if (instance_exists(obj_thebox)) {
        with (obj_thebox) {
            text = "* You look through your bag...";
            display_text = "";
            text_index = 0;
        }
    }
    // Aquí podrías abrir el inventario o aplicar un efecto curativo
    show_debug_message("ITEM selected");
}
